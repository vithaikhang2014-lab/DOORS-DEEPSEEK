-- // ESP Loop
local function getPlayerColor(plr)
    return Color3.fromHSV(math.abs(plr.UserId % 100)/100, 1, 0.8)
end

RunService.RenderStepped:Connect(function()
    if not espEnabled then
        for _,v in pairs(espLines) do v:Destroy() end
        espLines = {}
        return
    end
    
    for _,v in pairs(espLines) do v:Destroy() end
    espLines = {}
    
    -- ESP PLAYER
    for _,p in pairs(Players:GetPlayers()) do
        if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            local root = p.Character.HumanoidRootPart
            local pos, onScreen = camera:WorldToScreenPoint(root.Position)
            if onScreen then
                local bill = Instance.new("BillboardGui")
                bill.Size = UDim2.new(0, 150, 0, 40)
                bill.Adornee = root
                bill.AlwaysOnTop = true
                bill.Parent = root
                local nameLabel = Instance.new("TextLabel", bill)
                nameLabel.Size = UDim2.new(1,0,1,0)
                nameLabel.BackgroundTransparency = 1
                nameLabel.Text = p.Name .. "  |  " .. math.floor((root.Position - player.Character.HumanoidRootPart.Position).Magnitude) .. "m"
                nameLabel.TextColor3 = getPlayerColor(p)
                nameLabel.TextStrokeTransparency = 0.5
                table.insert(espLines, bill)
            end
        end
    end
    
    -- ESP Monster
    for _,v in pairs(workspace:GetDescendants()) do
        if v:IsA("Model") and v:FindFirstChild("Humanoid") and not Players:GetPlayerFromCharacter(v) then
            for _,name in pairs(monsterList) do
                if v.Name:lower():find(name:lower()) and v:FindFirstChild("HumanoidRootPart") then
                    local bill = Instance.new("BillboardGui")
                    bill.Size = UDim2.new(0, 120, 0, 30)
                    bill.Adornee = v.HumanoidRootPart
                    bill.AlwaysOnTop = true
                    bill.Parent = v.HumanoidRootPart
                    local monLabel = Instance.new("TextLabel", bill)
                    monLabel.Size = UDim2.new(1,0,1,0)
                    monLabel.BackgroundTransparency = 1
                    monLabel.Text = "⚠️ " .. v.Name .. " ⚠️"
                    monLabel.TextColor3 = Color3.fromRGB(255, 50, 50)
                    monLabel.TextScaled = true
                    table.insert(espLines, bill)
                    
                    if monsterDetectEnabled then
                        print("MONSTER DETECTED: " .. v.Name)
                        -- có thể thêm sound
                    end
                end
            end
        end
    end
end)

