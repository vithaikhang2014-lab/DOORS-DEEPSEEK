-- NOCLIP
local function SetNoclip(state)
    NoclipEnabled = state
    if NoclipConnection then NoclipConnection:Disconnect() end
    if state then
        NoclipConnection = RunService.Stepped:Connect(function()
            if Player.Character and Player.Character:FindFirstChild("Humanoid") then
                local humanoid = Player.Character.Humanoid
                for _, part in ipairs(Player.Character:GetDescendants()) do
                    if part:IsA("BasePart") and part.CanCollide then
                        part.CanCollide = false
                    end
                end
            end
        end)
    end
end

-- ESP (hiển thị tên entity & khoảng cách)
local function UpdateESP()
    for _, line in pairs(ESPLines) do
        if line and line.Remove then line:Remove() end
    end
    ESPLines = {}

    if not ESPEnabled then return end

    local function AddESP(instance, color)
        if not instance or not instance.Parent then return end
        local line = Drawing.new("Line")
        line.Thickness = 2
        line.Color = color
        line.Visible = true
        line.From = Vector2.new(0, 0)
        line.To = Vector2.new(0, 0)

        local text = Drawing.new("Text")
        text.Size = 14
        text.Center = true
        text.Outline = true
        text.Color = color
        text.Visible = true

        table.insert(ESPLines, {line, text, instance})
    end

    for _, v in ipairs(workspace:GetDescendants()) do
        if v:IsA("Model") and v:FindFirstChild("Humanoid") and v ~= Player.Character then
            local isEntity = v.Name:lower():find("entity") or v.Name:lower():find("rush") or v.Name:lower():find("ambush") or v.Name:lower():find("screech") or v.Name:lower():find("seek")
            if isEntity then
                AddESP(v, Color3.fromRGB(255, 50, 50))
            else
                AddESP(v, Color3.fromRGB(50, 150, 255))
            end
        elseif v:IsA("BasePart") and v.Name:lower():find("entity") then
            AddESP(v, Color3.fromRGB(255, 0, 0))
        end
    end

    RunService.RenderStepped:Connect(function()
        if not ESPEnabled then return end
        for _, data in pairs(ESPLines) do
            local inst = data[3]
            if inst and inst.Parent then
                local pos, onScreen = Camera:WorldToViewportPoint(inst.Position)
                if onScreen and pos.Z > 0 then
                    data[1].Visible = true
                    data[2].Visible = true
                    data[1].From = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
                    data[1].To = Vector2.new(pos.X, pos.Y)
                    local dist = (Camera.CFrame.Position - inst.Position).Magnitude
                    data[2].Text = inst.Name .. " | " .. math.floor(dist) .. "m"
                    data[2].Position = Vector2.new(pos.X, pos.Y - 20)
                else
                    data[1].Visible = false
                    data[2].Visible = false
                end
            else
                data[1].Visible = false
                data[2].Visible = false
            end
        end
    end)
end

-- Entity Detection (cảnh báo khi có entity gần)
local function EntityDetection()
    while EntityDetectionEnabled and task.wait(0.5) do
        if not EntityDetectionEnabled then break end
        local nearestDist = math.huge
        for _, v in ipairs(workspace:GetDescendants()) do
            if v:IsA("Model") and v:FindFirstChild("Humanoid") and v ~= Player.Character then
                local isEntity = v.Name:lower():find("entity") or v.Name:lower():find("rush") or v.Name:lower():find("ambush")
                if isEntity and Player.Character and Player.Character:FindFirstChild("HumanoidRootPart") then
                    local dist = (Player.Character.HumanoidRootPart.Position - v.PrimaryPart.Position).Magnitude
                    if dist < 30 and dist < nearestDist then
                        nearestDist = dist
                    end
                end
            end
        end
        if nearestDist < 30 then
            game:GetService("StarterGui"):SetCore("SendNotification", {
                Title = "⚠️ CẢNH BÁO ENTITY",
                Text = string.format("Entity cách bạn %.1f mét! CẨN THẬN!", nearestDist),
                Duration = 2
            })
        end
    end
end

