local createMinimizedButton = function(parent, onRestore)
    local minimized = Instance.new("ImageButton")
    minimized.Size = UDim2.new(0, 50, 0, 50)
    minimized.Position = UDim2.new(0, 20, 1, -70)
    minimized.BackgroundColor3 = Color3.fromRGB(25, 25, 35)
    minimized.BackgroundTransparency = 0.2
    minimized.BorderSizePixel = 0
    minimized.Image = "rbxassetid://6031094838" -- icon xoáy
    minimized.ImageColor3 = Color3.fromRGB(100, 200, 255)
    minimized.ScaleType = Enum.ScaleType.Fit
    minimized.Parent = parent
    
    -- Hiệu ứng xoay
    local spin = Instance.new("UIGradient")
    spin.Rotation = 0
    spin.Transparency = NumberSequence.new(0.3)
    minimized.UIGradient = spin
    
    spawn(function()
        while minimized and minimized.Parent do
            task.wait(0.03)
            if spin then spin.Rotation = (spin.Rotation + 5) % 360 end
        end
    end)
    
    minimized.MouseButton1Click:Connect(onRestore)
    return minimized
end

